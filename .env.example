# Operation Quicksilver — Environment Variables
# Copy this file to .env and fill in your values

# --- Required ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Admin ---
# Static bearer token for admin API endpoints
ADMIN_TOKEN=change-me-in-production

# --- Database (optional overrides; docker-compose defaults shown) ---
POSTGRES_PASSWORD=quicksilver_dev

# --- MinIO (optional overrides; docker-compose defaults shown) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_dev

# --- App ---
PORT=3001
NODE_ENV=development
